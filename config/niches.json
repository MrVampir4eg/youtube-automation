{
  "niches": [
    {
      "id": "motivation",
      "name": "Мотивація та Mindset",
      "description": "Мотиваційний контент, історії успіху, mindset",
      "target_cpm": 3.5,
      "voice": "Adam",
      "keywords": [
        "motivation",
        "success",
        "mindset",
        "discipline",
        "goals",
        "achievement",
        "inspiration",
        "self-improvement"
      ],
      "video_themes": [
        "mountain climbing",
        "ocean waves",
        "sunrise",
        "workout",
        "running",
        "meditation"
      ],
      "content_templates": [
        {
          "type": "success_story",
          "hook_template": "Ця людина {досягнення} за {час}. Як?",
          "body_structure": "challenge → struggle → breakthrough → result",
          "cta": "Підпишись щоб не пропустити історії успіху!"
        },
        {
          "type": "mindset_tip",
          "hook_template": "{Число} звичок мільярдерів, про які ніхто не говорить",
          "body_structure": "habit 1 → habit 2 → habit 3 → why it works",
          "cta": "Збережи щоб не забути!"
        },
        {
          "type": "quote_breakdown",
          "hook_template": "\"{цитата}\" - {автор}. Ось що це насправді означає...",
          "body_structure": "quote → context → deep meaning → application",
          "cta": "Натисни підписатись для більше мудрості!"
        }
      ]
    },
    {
      "id": "finance",
      "name": "Фінанси та Інвестиції",
      "description": "Фінансові поради, крипто, інвестиції",
      "target_cpm": 5.0,
      "voice": "Antoni",
      "keywords": [
        "finance",
        "money",
        "investing",
        "crypto",
        "stocks",
        "wealth",
        "passive income",
        "financial freedom"
      ],
      "video_themes": [
        "stock market",
        "city skyline",
        "office",
        "charts and graphs",
        "money",
        "technology"
      ],
      "content_templates": [
        {
          "type": "money_fact",
          "hook_template": "{Число}% людей НЕ знають цей факт про гроші...",
          "body_structure": "surprising fact → explanation → how to use → warning",
          "cta": "Підпишись для фінансових секретів!"
        },
        {
          "type": "investment_tip",
          "hook_template": "Я {результат} за {час} використовуючи цю стратегію",
          "body_structure": "result → strategy → step by step → risks",
          "cta": "Не пропусти наступні поради!"
        },
        {
          "type": "crypto_news",
          "hook_template": "{Крипто подія} - ось що це означає для твого портфоліо",
          "body_structure": "news → analysis → implications → action",
          "cta": "Слідкуй за крипто-новинами тут!"
        }
      ]
    },
    {
      "id": "history",
      "name": "Історія та Таємниці",
      "description": "Історичні факти, загадки, нерозкриті таємниці",
      "target_cpm": 2.5,
      "voice": "Bella",
      "keywords": [
        "history",
        "mystery",
        "ancient",
        "secrets",
        "civilization",
        "archaeology",
        "legends",
        "unsolved"
      ],
      "video_themes": [
        "ancient ruins",
        "historical sites",
        "old documents",
        "museums",
        "archaeology",
        "vintage"
      ],
      "content_templates": [
        {
          "type": "historical_mystery",
