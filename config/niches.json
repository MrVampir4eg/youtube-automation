          "body_structure": "mystery intro → facts → theories → conclusion",
          "cta": "Підпишись для більше історичних таємниць!"
        },
        {
          "type": "historical_fact",
          "hook_template": "{Число} шокуючих фактів про {історична подія}",
          "body_structure": "fact 1 → fact 2 → fact 3 → why it matters",
          "cta": "Дізнавайся більше історії з нами!"
        },
        {
          "type": "person_story",
          "hook_template": "{Історична особа} зробила щось неймовірне...",
          "body_structure": "who → what they did → how → impact",
          "cta": "Більше історій великих людей тут!"
        }
      ]
    },
    {
      "id": "tech",
      "name": "Tech та AI",
      "description": "Технологічні новини, AI, гаджети",
      "target_cpm": 4.5,
      "voice": "Josh",
      "keywords": [
        "technology",
        "AI",
        "artificial intelligence",
        "gadgets",
        "innovation",
        "future",
        "science",
        "tech news"
      ],
      "video_themes": [
        "technology",
        "coding",
        "AI",
        "robots",
        "futuristic",
        "data center"
      ],
      "content_templates": [
        {
          "type": "ai_news",
          "hook_template": "Цей новий AI {досягнення} - майбутнє вже тут",
          "body_structure": "what → how it works → implications → timeline",
          "cta": "Слідкуй за AI-новинами тут!"
