        {
          "type": "tech_explained",
          "hook_template": "Як працює {технологія}? Пояснюю за 60 секунд",
          "body_structure": "simple explanation → deeper dive → real-world use → future",
          "cta": "Підпишись для tech-освіти!"
        },
        {
          "type": "gadget_review",
          "hook_template": "Протестував {гаджет} - ось що я виявив...",
          "body_structure": "first impression → testing → pros/cons → verdict",
          "cta": "Більше огляд гаджетів тут!"
        }
      ]
    },
    {
      "id": "productivity",
      "name": "Продуктивність та Лайфхаки",
      "description": "Поради по продуктивності, life hacks, time management",
      "target_cpm": 3.0,
      "voice": "Adam",
      "keywords": [
        "productivity",
        "life hacks",
        "time management",
        "efficiency",
        "work",
        "study",
        "organization",
        "habits"
      ],
      "video_themes": [
        "workspace",
        "planning",
        "desk setup",
        "studying",
        "organized",
        "calendar"
      ],
      "content_templates": [
        {
          "type": "productivity_hack",
          "hook_template": "Цей лайфхак збереже тобі {час} щодня",
          "body_structure": "problem → solution → how to implement → results",
          "cta": "Підпишись для більше лайфхаків!"
        },
        {
          "type": "routine_breakdown",
          "hook_template": "Моя {час дня} рутина для максимальної продуктивності",
          "body_structure": "morning → key activities → why it works → try it",
          "cta": "Більше продуктивних рутин тут!"
        },
        {
          "type": "tool_recommendation",
          "hook_template": "{Число} інструментів які змінять твою продуктивність",
          "body_structure": "tool 1 → tool 2 → tool 3 → how to start",
          "cta": "Не пропусти наступні інструменти!"
        }
      ]
    }
  ],

  "global_settings": {
    "min_duration_seconds": 45,
    "max_duration_seconds": 55,
    "target_hook_seconds": 3,
    "target_cta_seconds": 5,
    "words_per_second": 2.5,
    "preferred_aspect_ratio": "9:16",
    "video_resolution": "1080x1920"
  },

  "seo_templates": {
    "title_formats": [
      "{hook} | {topic}",
      "{number} {topic} That {benefit}",
      "The {adjective} Truth About {topic}",
      "{topic}: What Nobody Tells You",
      "I {action} and Here's What Happened"
    ],
    "description_template": "🔥 {hook}\n\n{summary}\n\n💡 {cta}\n\n📌 Timestamps:\n0:00 - Intro\n0:03 - {main_point_1}\n0:30 - {main_point_2}\n0:50 - Conclusion\n\n🎯 Subscribe for more {niche} content!\n\n#Shorts #{niche} #{keyword1} #{keyword2}",
    "tags_strategy": "Mix of broad + niche + trending tags (max 500 chars)"
  },

  "quality_checks": {
    "min_hook_impact_score": 7,
    "max_ai_detection_probability": 0.6,
    "required_cta_presence": true,
    "forbidden_words": [
      "clickbait",
      "fake",
      "scam",
      "illegal",
      "hack (in security context)"
    ]
  }
}
