# YouTube Shorts Automation System
# Environment Configuration Template

# =================================
# AI API KEYS
# =================================

# OpenAI API (для генерації скриптів)
# Отримати: https://platform.openai.com/api-keys
# Рекомендовано: GPT-4o-mini (найдешевший - $0.15/1M tokens)
OPENAI_API_KEY=sk-proj-...

# Альтернатива: Claude API (Anthropic)
# Отримати: https://console.anthropic.com/
# Uncomment якщо хочете використовувати Claude замість OpenAI
# ANTHROPIC_API_KEY=sk-ant-...

# Який AI використовувати (openai або anthropic)
AI_PROVIDER=openai

# =================================
# VOICE SYNTHESIS
# =================================

# ElevenLabs API (озвучка)
# Отримати: https://elevenlabs.io/
# План: Starter ($5/міс - 30K characters)
ELEVENLABS_API_KEY=...

# Голоси для різних ніш
VOICE_MOTIVATION=Adam
VOICE_FINANCE=Antoni
VOICE_HISTORY=Bella
VOICE_TECH=Josh

# =================================
# YOUTUBE API
# =================================

# YouTube Data API v3
# Налаштування: https://console.cloud.google.com/
# 1. Створити проєкт
# 2. Увімкнути YouTube Data API v3
# 3. Створити OAuth 2.0 credentials
# 4. Додати redirect URI: http://localhost:5000/oauth2callback

YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:5000/oauth2callback
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private

# =================================
# VIDEO CONTENT SOURCES
# =================================

# Pexels API (безкоштовні відео/фото)
# Отримати: https://www.pexels.com/api/
PEXELS_API_KEY=...

# Pixabay API (backup джерело)
# Отримати: https://pixabay.com/api/docs/
PIXABAY_API_KEY=...

# =================================
# DATABASE
# =================================

# SQLite (локальна БД - за замовчуванням)
DATABASE_URL=sqlite:///youtube_automation.db

# Для production можна використати PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/dbname

# =================================
# FLASK CONFIGURATION
# =================================

# Секретний ключ для Flask (згенеруйте випадковий)
# Генерація: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Flask порт
FLASK_PORT=5000

# Debug mode (False для production)
FLASK_DEBUG=True

# =================================
# SCHEDULER SETTINGS
# =================================

# Часовий пояс (Europe/Kiev для України)
TIMEZONE=Europe/Kiev

# Скільки відео генерувати на день
VIDEOS_PER_DAY=3

# Час генерації (година в 24-форматі)
GENERATION_TIME=3

# =================================
# CONTENT SETTINGS
# =================================

# Скільки ніш активних одночасно
ACTIVE_NICHES=3

# Теми каналу через кому. Залиште порожнім, щоб використовувати всі.
CONTENT_NICHES=fun_facts,everyday_humor,psychology,history,productivity

# Тривалість відео (секунди)
VIDEO_MIN_DURATION=25
VIDEO_MAX_DURATION=38

# Якість відео (720, 1080)
VIDEO_QUALITY=1080

# FPS
VIDEO_FPS=30

# Обмеження RAM для Render Free
LOW_MEMORY_MODE=True
VIDEO_WIDTH=540
VIDEO_HEIGHT=960
VIDEO_THREADS=1
VIDEO_PRESET=ultrafast

# =================================
# API USAGE LIMITS (захист від overuse)
# =================================

# Максимальна вартість на день ($)
MAX_DAILY_COST=5.00

# Максимум OpenAI tokens на запит
MAX_TOKENS_PER_REQUEST=500

# Максимум ElevenLabs characters на день
MAX_ELEVENLABS_CHARS_PER_DAY=1000

# =================================
# MONETIZATION TRACKING
# =================================

# YouTube Analytics API (опційно)
# Для автоматичного трекінгу доходів
ENABLE_ANALYTICS=True

# Email для сповіщень
NOTIFICATION_EMAIL=your-email@gmail.com

# =================================
# DEPLOYMENT
# =================================

# Хостинг (local, railway, render)
DEPLOYMENT_ENV=local

# Railway/Render токен (якщо потрібно)
# RAILWAY_TOKEN=...
# RENDER_API_KEY=...

# =================================
# LOGGING
# =================================

# Рівень логування (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Зберігати логи в файл
ENABLE_FILE_LOGGING=True

# =================================
# FEATURE FLAGS
# =================================

# Увімкнути автоматичну публікацію
AUTO_UPLOAD=True

# Додавати субтитри автоматично
AUTO_CAPTIONS=True

# Динамічний монтаж та короткі caption-блоки
SCENE_DURATION_SECONDS=4.5
CAPTION_WORDS=3
CAPTION_Y_RATIO=0.62

# Безкоштовний природний голос; gTTS використовується автоматично при збої
FREE_TTS_PROVIDER=edge
EDGE_TTS_VOICE=
EDGE_TTS_RATE=+8%
EDGE_TTS_PITCH=+0Hz

# Використовувати AI для оптимізації заголовків/тегів
AI_SEO_OPTIMIZATION=True

# =================================
# TESTING
# =================================

# Тестовий режим (не публікувати реально на YouTube)
TEST_MODE=False

# Скільки відео згенерувати для тесту
TEST_VIDEO_COUNT=3
