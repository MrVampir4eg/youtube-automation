# YouTube Shorts Automation System
# Environment Configuration Template

# =================================
# AI API KEYS
# =================================

# OpenAI API (для генерації скриптів)
# Отримати: https://platform.openai.com/api-keys
# Рекомендовано: GPT-4o-mini (найдешевший - $0.15/1M tokens)
OPENAI_API_KEY=sk-proj-...

# Альтернатива: Claude API (Anthropic)
# Отримати: https://console.anthropic.com/
# Uncomment якщо хочете використовувати Claude замість OpenAI
# ANTHROPIC_API_KEY=sk-ant-...

# Який AI використовувати (openai або anthropic)
AI_PROVIDER=openai

# =================================
# VOICE SYNTHESIS
# =================================

# ElevenLabs API (озвучка)
# Отримати: https://elevenlabs.io/
# План: Starter ($5/міс - 30K characters)
ELEVENLABS_API_KEY=...

# Голоси для різних ніш
VOICE_MOTIVATION=Adam
VOICE_FINANCE=Antoni
VOICE_HISTORY=Bella
VOICE_TECH=Josh

# =================================
# YOUTUBE API
# =================================

# YouTube Data API v3
# Налаштування: https://console.cloud.google.com/
# 1. Створити проєкт
# 2. Увімкнути YouTube Data API v3
# 3. Створити OAuth 2.0 credentials
# 4. Додати redirect URI: http://localhost:5000/oauth2callback

YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:5000/oauth2callback
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public

# =================================
# VIDEO CONTENT SOURCES
# =================================

# Pexels API (безкоштовні відео/фото)
# Отримати: https://www.pexels.com/api/
PEXELS_API_KEY=...

# Pixabay API (backup джерело)
# Отримати: https://pixabay.com/api/docs/
PIXABAY_API_KEY=...

# =================================
# DATABASE
# =================================

# SQLite (локальна БД - за замовчуванням)
DATABASE_URL=sqlite:///youtube_automation.db

# На Render задайте цей шлях після підключення Persistent Disk до /var/data.
# Це зберігає додаткові профілі YouTube та партнерські пропозиції між redeploy.
# DATABASE_PATH=/var/data/youtube_automation.db

# Для production можна використати PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/dbname

# =================================
# FLASK CONFIGURATION
# =================================

# Єдиний адміністратор. ADMIN_PASSWORD потрібен тільки для першого створення
# облікового запису; далі пароль змінюється всередині захищеної адмінки.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=REPLACE_WITH_12_PLUS_CHARS_UPPER_LOWER_NUMBER

# Секретний ключ для Flask (згенеруйте випадковий)
# Генерація: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Окремий випадковий токен для GitHub Actions / офіційного API-бота.
# Те саме значення додайте у GitHub Actions secret AUTOMATION_API_TOKEN.
AUTOMATION_API_TOKEN=REPLACE_WITH_ANOTHER_LONG_RANDOM_VALUE

# Не більше 3 автоматичних публікацій на один профіль за останні 24 години.
BOT_MAX_DAILY_POSTS_PER_PROFILE=3

# Публічна адреса потрібна для reset-посилань і platform callbacks.
PUBLIC_BASE_URL=https://your-service.onrender.com

# SMTP для відновлення пароля. Для Gmail використовуйте App Password,
# а не звичайний пароль облікового запису.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=owner@example.com
SMTP_PASSWORD=REPLACE_WITH_EMAIL_APP_PASSWORD
SMTP_FROM_EMAIL=owner@example.com
SMTP_USE_SSL=False

# Flask порт
FLASK_PORT=5000

# Debug mode (False для production)
FLASK_DEBUG=False

# =================================
# SCHEDULER SETTINGS
# =================================

# Часовий пояс України
TIMEZONE=Europe/Kyiv

# Скільки відео генерувати на день
VIDEOS_PER_DAY=0

# False: використовувати GitHub Actions графік 4 рази на день
ENABLE_INTERNAL_SCHEDULER=False

# Час генерації (година в 24-форматі)
GENERATION_TIME=3

# =================================
# CONTENT SETTINGS
# =================================

# Скільки ніш активних одночасно
ACTIVE_NICHES=3

# Теми каналу через кому. Залиште порожнім, щоб використовувати всі.
CONTENT_NICHES=mini_stories,fun_facts,everyday_humor,internet_culture,psychology,history,tech,productivity
AUTO_EXPAND_NICHES=True

# Ринкові сигнали Google Trends UA + локальна перевірка якості сценарію
ENABLE_MARKET_TRENDS=True
MARKET_GEO=UA
TARGET_AUDIENCE=україномовні глядачі 18-34 років
SCRIPT_MAX_ATTEMPTS=2
MIN_SCRIPT_QUALITY_SCORE=78

# Тривалість відео (секунди)
VIDEO_MIN_DURATION=18
VIDEO_MAX_DURATION=35

# Динамічний монтаж і captions
AUTO_CAPTIONS=True
SCENE_DURATION_SECONDS=2.8
CAPTION_WORDS=3
CAPTION_Y_RATIO=0.62

# Якість відео (720, 1080)
VIDEO_QUALITY=1080

# FPS
VIDEO_FPS=30

# Обмеження RAM для Render Free
LOW_MEMORY_MODE=True
VIDEO_WIDTH=540
VIDEO_HEIGHT=960
VIDEO_THREADS=1
VIDEO_PRESET=ultrafast

# =================================
# API USAGE LIMITS (захист від overuse)
# =================================

# Максимальна вартість на день ($)
MAX_DAILY_COST=5.00

# Максимум OpenAI tokens на запит
MAX_TOKENS_PER_REQUEST=500

# Максимум ElevenLabs characters на день
MAX_ELEVENLABS_CHARS_PER_DAY=1000

# =================================
# MONETIZATION TRACKING
# =================================

# YouTube Analytics API (опційно)
# Для автоматичного трекінгу доходів
ENABLE_ANALYTICS=True

# Email для сповіщень
NOTIFICATION_EMAIL=your-email@gmail.com

# =================================
# DEPLOYMENT
# =================================

# Хостинг (local, railway, render)
DEPLOYMENT_ENV=local

# Railway/Render токен (якщо потрібно)
# RAILWAY_TOKEN=...
# RENDER_API_KEY=...

# =================================
# LOGGING
# =================================

# Рівень логування (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Зберігати логи в файл
ENABLE_FILE_LOGGING=True

# =================================
# FEATURE FLAGS
# =================================

# Увімкнути автоматичну публікацію
AUTO_UPLOAD=True

# Додавати субтитри автоматично
AUTO_CAPTIONS=True

# Динамічний монтаж та короткі caption-блоки
SCENE_DURATION_SECONDS=4.5
CAPTION_WORDS=3
CAPTION_Y_RATIO=0.62

# Безкоштовний природний голос; gTTS використовується автоматично при збої
FREE_TTS_PROVIDER=edge
EDGE_TTS_VOICE=
EDGE_TTS_RATE=+8%
EDGE_TTS_PITCH=+0Hz

# Використовувати AI для оптимізації заголовків/тегів
AI_SEO_OPTIMIZATION=True

# =================================
# TESTING
# =================================

# Тестовий режим (не публікувати реально на YouTube)
TEST_MODE=False

# Скільки відео згенерувати для тесту
TEST_VIDEO_COUNT=3
