# Existing generation and YouTube settings stay unchanged.
AUTO_UPLOAD=True
AUTO_PUBLISH_PLATFORMS=youtube,instagram,facebook,tiktok
PUBLIC_BASE_URL=https://youtube-automation-zoiy.onrender.com
MEDIA_SHARE_SECRET=REPLACE_WITH_A_LONG_RANDOM_VALUE

# growth = 18-35 seconds; rewards = 62-80 seconds.
CONTENT_PROFILE=growth

# Instagram professional account (optional).
INSTAGRAM_USER_ID=REPLACE_ME
INSTAGRAM_ACCESS_TOKEN=REPLACE_ME

# Facebook Page (optional).
FACEBOOK_PAGE_ID=REPLACE_ME
FACEBOOK_PAGE_ACCESS_TOKEN=REPLACE_ME

# TikTok Content Posting API (optional; inbox is the safe default).
TIKTOK_ACCESS_TOKEN=REPLACE_ME
TIKTOK_POST_MODE=inbox

# Only after TikTok approves Direct Post for the developer app:
# TIKTOK_DIRECT_POST_APPROVED=True
# TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Update this only when Meta requires a newer supported Graph API version.
META_GRAPH_API_VERSION=v25.0
